<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ═══ TARGET BAR ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="目标设备"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <Spinner android:id="@+id/spinnerDevice"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="4dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:hint="AID">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAid" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="number" android:text="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:layout_weight="1" android:hint="TID">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTid" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="number" android:text="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:layout_weight="1" android:hint="SEQ">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSeq" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="number" android:text="0" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:hint="目标 IP">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etIp" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="textUri" android:text="127.0.0.1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:layout_weight="1" android:hint="端口">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPort" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="number" android:text="9876" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView android:id="@+id/tvRouteSummary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="路由：-"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/gsyn_info" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ TAB BAR ═══ -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:tabGravity="fill" app:tabMode="fixed" />

        <!-- ═══ TAB 0: 控制 ═══ -->
        <LinearLayout android:id="@+id/tabControl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:orientation="vertical" android:visibility="visible">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardUseCompatPadding="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="控制指令" android:textAppearance="@style/TextAppearance.Material3.TitleSmall" android:textStyle="bold" />

                    <!-- PING 0x01 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="PING" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x01"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendPing"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- PONG 0x02 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="PONG" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x02"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendPong"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- ID_REQUEST 0x03 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="ID_REQUEST" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x03"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendIdRequest"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- ID_ASSIGN 0x05 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="ID_ASSIGN" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x05"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendIdAssign"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- TIME_REQUEST 0x07 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="TIME_REQUEST" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x07"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendTimeRequest"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- HANDSHAKE_ACK 0x09 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="HANDSHAKE_ACK" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x09"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendHsAck"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- HANDSHAKE_NACK 0x0A -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="HANDSHAKE_NACK" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x0A"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendHsNack"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                    <!-- SECURE_DICT_READY 0x10 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="SECURE_DICT_READY" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:text="0x10"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="@color/gsyn_info"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendSecureDict"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="发送" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ═══ TAB 1: 数据 ═══ -->
        <LinearLayout android:id="@+id/tabData"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:orientation="vertical" android:visibility="gone">

            <!-- Single sensor -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardUseCompatPadding="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="单传感器数据帧" android:textAppearance="@style/TextAppearance.Material3.TitleSmall" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:text="传感器 ID"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <Spinner android:id="@+id/spinnerSensorId"
                        android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="2dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:text="单位" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <Spinner android:id="@+id/spinnerUnit"
                                android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:text="状态" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <Spinner android:id="@+id/spinnerState"
                                android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:hint="数值 (Value)">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etValue" android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned" android:text="25.0" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnSendSingle"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="单帧发送 DATA_FULL" />
                    <TextView android:id="@+id/tvSinglePreview"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="预览：-"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Multi-sensor -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" app:cardUseCompatPadding="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="多传感器数据帧" android:textAppearance="@style/TextAppearance.Material3.TitleSmall" android:textStyle="bold" />
                    <LinearLayout android:id="@+id/containerMultiSensor"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:orientation="vertical" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAddSensor"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="＋ 添加行" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSendMulti"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:layout_weight="1" android:text="发送多帧" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ═══ TAB 2: 原始 ═══ -->
        <LinearLayout android:id="@+id/tabRaw"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:orientation="vertical" android:visibility="gone">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardUseCompatPadding="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Raw HEX, e.g. 01 00 00 00 01 01 00 …">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRaw" android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapCharacters" android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnSendRaw"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="发送 Raw HEX" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="CMD 参考表"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" android:textStyle="bold" />
                    <TextView android:id="@+id/tvCmdRef"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:fontFamily="monospace"
                        android:text="加载中…"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ═══ LOG PANEL ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp" app:cardUseCompatPadding="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Dispatch Console"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall" android:textStyle="bold" />
                <TextView android:id="@+id/tvLastResult"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="最近一次发送：尚未执行"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/gsyn_info" />
                <TextView android:id="@+id/tvLog"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:minHeight="120dp"
                    android:text="发送日志\n\n尚未下发命令。"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>

